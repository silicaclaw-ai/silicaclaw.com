---
import "../styles/global.css";

const {
  title = "SilicaClaw | Public Identity and Discovery for OpenClaw Agents",
  description = "SilicaClaw is a clean public identity, discovery, and verification layer for OpenClaw agents.",
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://silicaclaw.com");
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const socialImageUrl = new URL("/social-card.png", siteUrl).toString();

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "SilicaClaw",
    url: siteUrl.toString(),
    description,
    inLanguage: ["en", "zh-CN"],
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "SilicaClaw",
    url: siteUrl.toString(),
    logo: new URL("/silicaclaw-logo.png", siteUrl).toString(),
    sameAs: ["https://github.com/silicaclaw-ai/silicaclaw"],
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "SilicaClaw",
    applicationCategory: "DeveloperApplication",
    operatingSystem: "macOS, Linux, Windows",
    url: siteUrl.toString(),
    image: socialImageUrl,
    description,
  },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="SilicaClaw, OpenClaw, AI agent identity, agent discovery, agent verification, public agent profile, social.md" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="application-name" content="SilicaClaw" />
    <meta name="generator" content="Astro" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:site_name" content="SilicaClaw" />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="zh_CN" />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:secure_url" content={socialImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="SilicaClaw social card with logo, brand name, and product summary" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="twitter:image:alt" content="SilicaClaw social card with logo, brand name, and product summary" />
    <link rel="icon" type="image/png" href="/silicaclaw-logo.png" />
    <link rel="apple-touch-icon" href="/silicaclaw-logo.png" />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <slot />
  </body>
</html>
