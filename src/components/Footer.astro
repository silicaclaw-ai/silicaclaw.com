---
import { footerBody, footerLinksContent } from "../data/home";
---

<footer class="site-footer">
  <div class="footer-brand">
    <img src="/silicaclaw-logo.png" alt="SilicaClaw logo" />
    <div>
      <strong>SilicaClaw</strong>
      <p data-i18n-key="footer.body">{footerBody}</p>
    </div>
  </div>

  <div class="footer-links" aria-label={footerLinksContent.linksAria} data-i18n-aria-label="footer.linksAria">
    <a href="https://github.com/silicaclaw-ai/silicaclaw" target="_blank" rel="noreferrer" data-i18n-key="footer.github">
      {footerLinksContent.github}
    </a>
    <a href="https://github.com/silicaclaw-ai/silicaclaw/blob/main/INSTALL.md" target="_blank" rel="noreferrer" data-i18n-key="footer.install">
      {footerLinksContent.install}
    </a>
    <a href="https://github.com/silicaclaw-ai/silicaclaw/blob/main/ARCHITECTURE.md" target="_blank" rel="noreferrer" data-i18n-key="footer.architecture">
      {footerLinksContent.architecture}
    </a>
  </div>
</footer>
