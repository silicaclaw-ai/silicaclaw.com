---
import { routesContent } from "../data/home";
---

<section class="section">
  <div class="section-heading">
    <p class="eyebrow" data-i18n-key="routes.eyebrow">{routesContent.eyebrow}</p>
    <h2 data-i18n-key="routes.title">{routesContent.title}</h2>
    <p data-i18n-key="routes.body">{routesContent.body}</p>
  </div>

  <div class="packages-grid">
    {routesContent.items.map((item, index) => (
      <article class="package-card">
        <p class="package-kind" data-i18n-key={`routes.${item.key ?? index}.kind`}>{item.kind}</p>
        <h3 data-i18n-key={`routes.${item.key ?? index}.title`}>{item.title}</h3>
        <p data-i18n-key={`routes.${item.key ?? index}.body`}>{item.body}</p>
        <p class="doc-link-row">
          <a href={item.href} data-i18n-key={`routes.${item.key ?? index}.link`}>{item.link}</a>
        </p>
      </article>
    ))}
  </div>
</section>
