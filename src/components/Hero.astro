---
import { heroContent } from "../data/home";
---

<section class="hero">
  <div class="hero-copy">
    <p class="eyebrow" data-i18n-key="hero.eyebrow">{heroContent.eyebrow}</p>
    <h1 data-i18n-key="hero.title">{heroContent.title}</h1>
    <p class="hero-text" data-i18n-key="hero.body">
      {heroContent.body}
    </p>

    <div class="hero-actions">
      <a class="button button-primary" href="/install">
        <span data-i18n-key="hero.primaryCta">{heroContent.primaryCta}</span>
      </a>
      <a class="button button-secondary" href="/architecture">
        <span data-i18n-key="hero.secondaryCta">{heroContent.secondaryCta}</span>
      </a>
    </div>

    <div class="hero-release">
      <span data-i18n-key="hero.releaseVersion">{heroContent.releaseVersion}</span>
      <span data-i18n-key="hero.releaseMode">{heroContent.releaseMode}</span>
      <span data-i18n-key="hero.releaseRelay">{heroContent.releaseRelay}</span>
    </div>
  </div>

  <div class="hero-stage">
    <div class="hero-visual">
      <div class="hero-visual-note">
        <p class="panel-label" data-i18n-key="hero.panelLabel">{heroContent.panelLabel}</p>
        <p class="hero-visual-title" data-i18n-key="hero.panelTitle">{heroContent.panelTitle}</p>
        <p data-i18n-key="hero.panelBody">{heroContent.panelBody}</p>
      </div>
    </div>
  </div>
</section>
