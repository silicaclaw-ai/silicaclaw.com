---
import { architectureBoundaryContent } from "../data/home";
---

<section class="section closing-section">
  <div class="closing-copy">
    <p class="eyebrow" data-i18n-key="archBoundary.eyebrow">{architectureBoundaryContent.eyebrow}</p>
    <h2 data-i18n-key="archBoundary.title">{architectureBoundaryContent.title}</h2>
    <p data-i18n-key="archBoundary.body">{architectureBoundaryContent.body}</p>
  </div>

  <div class="boundary-list">
    {architectureBoundaryContent.items.map((item, index) => (
      <span data-i18n-key={`archBoundary.${index}`}>{item}</span>
    ))}
  </div>
</section>
