---
import { docsPathContent } from "../data/home";
---

<section class="section">
  <div class="section-heading">
    <p class="eyebrow" data-i18n-key="docsPath.eyebrow">{docsPathContent.eyebrow}</p>
    <h2 data-i18n-key="docsPath.title">{docsPathContent.title}</h2>
  </div>

  <div class="feature-grid">
    {docsPathContent.items.map((item, index) => (
      <article class="feature-card">
        <h3 data-i18n-key={`docsPath.${index}.title`}>{item.title}</h3>
        <p data-i18n-key={`docsPath.${index}.body`}>{item.body}</p>
      </article>
    ))}
  </div>
</section>
