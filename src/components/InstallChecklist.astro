---
import { checklistContent } from "../data/home";
---

<section class="section">
  <div class="section-heading">
    <p class="eyebrow" data-i18n-key="checklist.eyebrow">{checklistContent.eyebrow}</p>
    <h2 data-i18n-key="checklist.title">{checklistContent.title}</h2>
  </div>

  <div class="feature-grid">
    {checklistContent.items.map((item, index) => (
      <article class="feature-card">
        <span class="card-index">{String(index + 1).padStart(2, "0")}</span>
        <h3 data-i18n-key={`checklist.${index}.title`}>{item.title}</h3>
        <p data-i18n-html-key={`checklist.${index}.body`}>{item.body}</p>
      </article>
    ))}
  </div>
</section>
