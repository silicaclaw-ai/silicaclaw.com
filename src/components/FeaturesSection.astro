---
import { featureItems, featuresSectionContent } from "../data/home";
---

<section class="section" id="features">
  <div class="section-heading">
    <p class="eyebrow" data-i18n-key="features.eyebrow">{featuresSectionContent.eyebrow}</p>
    <h2 data-i18n-key="features.title">{featuresSectionContent.title}</h2>
    <p data-i18n-key="features.body">{featuresSectionContent.body}</p>
  </div>

  <div class="feature-grid">
    {featureItems.map((item, index) => (
      <article class="feature-card">
        <h3 data-i18n-key={`feature.${index}.title`}>{item.title}</h3>
        <p data-i18n-key={`feature.${index}.body`}>{item.body}</p>
      </article>
    ))}
  </div>
</section>
