---
import { architectureHeroContent, sharedContent } from "../data/home";
---

<section class="install-hero">
  <div class="install-hero-copy">
    <p class="eyebrow" data-i18n-key="archHero.eyebrow">{architectureHeroContent.eyebrow}</p>
    <h1 data-i18n-key="archHero.title">{architectureHeroContent.title}</h1>
    <p class="hero-text" data-i18n-key="archHero.body">{architectureHeroContent.body}</p>

    <div class="hero-actions">
      <a class="button button-primary" href="#layers">
        <span data-i18n-key="archHero.primaryCta">{architectureHeroContent.primaryCta}</span>
      </a>
      <a class="button button-secondary" href="/">
        <span data-i18n-key="shared.backHome">{sharedContent.backHome}</span>
      </a>
    </div>
  </div>

  <div class="install-hero-card">
    <p class="panel-label" data-i18n-key="archHero.panelLabel">{architectureHeroContent.panelLabel}</p>
    <h2 data-i18n-key="archHero.panelTitle">{architectureHeroContent.panelTitle}</h2>
    <p data-i18n-key="archHero.panelBody">{architectureHeroContent.panelBody}</p>
  </div>
</section>
