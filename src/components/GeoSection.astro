---
import { geoContent } from "../data/home";
---

<section class="section">
  <div class="section-heading">
    <p class="eyebrow" data-i18n-key="geo.eyebrow">{geoContent.eyebrow}</p>
    <h2 data-i18n-key="geo.title">{geoContent.title}</h2>
    <p data-i18n-key="geo.body">{geoContent.body}</p>
  </div>

  <div class="packages-grid">
    {geoContent.items.map((item, index) => (
      <article class="package-card">
        <p class="package-kind" data-i18n-key={`geo.${index}.kind`}>{item.kind}</p>
        <h3 data-i18n-key={`geo.${index}.title`}>{item.title}</h3>
        <p data-i18n-key={`geo.${index}.body`}>{item.body}</p>
      </article>
    ))}
  </div>
</section>
