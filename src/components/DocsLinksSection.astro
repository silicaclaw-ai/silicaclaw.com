---
import { docsLinksContent } from "../data/home";
---

<section class="section" id="doc-links">
  <div class="section-heading">
    <p class="eyebrow" data-i18n-key="docsLinks.eyebrow">{docsLinksContent.eyebrow}</p>
    <h2 data-i18n-key="docsLinks.title">{docsLinksContent.title}</h2>
  </div>

  <div class="packages-grid docs-grid">
    {docsLinksContent.items.map((doc, index) => (
      <article class="package-card">
        <p class="package-kind" data-i18n-key={`docsLinks.${index}.kind`}>{doc.kind}</p>
        <h3><code data-i18n-key={`docsLinks.${index}.title`}>{doc.title}</code></h3>
        <p data-i18n-key={`docsLinks.${index}.body`}>{doc.body}</p>
        <p class="doc-link-row">
          <a href={doc.href} target="_blank" rel="noreferrer" data-i18n-key={`docsLinks.${index}.link`}>
            {doc.link}
          </a>
        </p>
      </article>
    ))}
  </div>
</section>
