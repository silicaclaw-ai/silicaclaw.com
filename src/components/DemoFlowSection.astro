---
import { demoFlowContent } from "../data/home";
---

<section class="section">
  <div class="section-heading">
    <p class="eyebrow" data-i18n-key="demoFlow.eyebrow">{demoFlowContent.eyebrow}</p>
    <h2 data-i18n-key="demoFlow.title">{demoFlowContent.title}</h2>
    <p data-i18n-key="demoFlow.body">{demoFlowContent.body}</p>
  </div>

  <div class="feature-grid">
    {demoFlowContent.items.map((item, index) => (
      <article class="feature-card">
        <p class="package-kind" data-i18n-key={`demoFlow.${index}.kind`}>{item.kind}</p>
        <h3 data-i18n-key={`demoFlow.${index}.title`}>{item.title}</h3>
        <p data-i18n-key={`demoFlow.${index}.body`}>{item.body}</p>
      </article>
    ))}
  </div>
</section>
