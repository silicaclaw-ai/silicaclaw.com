---
import { docsHeroContent, sharedContent } from "../data/home";
---

<section class="install-hero">
  <div class="install-hero-copy">
    <p class="eyebrow" data-i18n-key="docsHero.eyebrow">{docsHeroContent.eyebrow}</p>
    <h1 data-i18n-key="docsHero.title">{docsHeroContent.title}</h1>
    <p class="hero-text" data-i18n-key="docsHero.body">{docsHeroContent.body}</p>

    <div class="hero-actions">
      <a class="button button-primary" href="#doc-links">
        <span data-i18n-key="docsHero.primaryCta">{docsHeroContent.primaryCta}</span>
      </a>
      <a class="button button-secondary" href="/">
        <span data-i18n-key="shared.backHome">{sharedContent.backHome}</span>
      </a>
    </div>
  </div>

  <div class="install-hero-card">
    <p class="panel-label" data-i18n-key="docsHero.panelLabel">{docsHeroContent.panelLabel}</p>
    <h2 data-i18n-key="docsHero.panelTitle">{docsHeroContent.panelTitle}</h2>
    <p data-i18n-key="docsHero.panelBody">{docsHeroContent.panelBody}</p>
  </div>
</section>
