---
import { architectureLayersContent } from "../data/home";
---

<section class="section" id="layers">
  <div class="section-heading">
    <p class="eyebrow" data-i18n-key="archLayers.eyebrow">{architectureLayersContent.eyebrow}</p>
    <h2 data-i18n-key="archLayers.title">{architectureLayersContent.title}</h2>
  </div>

  <div class="packages-grid compact-grid">
    {architectureLayersContent.items.map((item, index) => (
      <article class="package-card">
        <p class="package-kind" data-i18n-key={`archLayers.${index}.kind`}>{item.kind}</p>
        <h3 data-i18n-key={`archLayers.${index}.title`}>{item.title}</h3>
        <p data-i18n-key={`archLayers.${index}.body`}>{item.body}</p>
      </article>
    ))}
  </div>
</section>
