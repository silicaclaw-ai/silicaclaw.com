---
import { faqContent } from "../data/home";
---

<section class="section">
  <div class="section-heading">
    <p class="eyebrow" data-i18n-key="faq.eyebrow">{faqContent.eyebrow}</p>
    <h2 data-i18n-key="faq.title">{faqContent.title}</h2>
  </div>

  <div class="faq-list">
    {faqContent.items.map((item, index) => (
      <article class="faq-item">
        <h3 data-i18n-key={`faq.${index}.q`}>{item.question}</h3>
        <p data-i18n-key={`faq.${index}.a`}>{item.answer}</p>
      </article>
    ))}
  </div>
</section>
